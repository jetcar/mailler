# Test OIDC Provider Configuration - STANDALONE ONLY
# This file is used when running test-oidc-provider standalone (npm start)
# When running via docker-compose, variables come from the parent .env file

# Server
PORT=9000
ISSUER=http://localhost:9000

# Client credentials (must match your application's OIDC_CLIENT_ID and OIDC_CLIENT_SECRET)
CLIENT_ID=MailuId
CLIENT_SECRET=local-test-client-secret

# Hardcoded user data
USER_SUB=test-user-12345
USER_EMAIL=test@example.com
USER_NAME=Test User
USER_PREFERRED_USERNAME=testuser

# JWT signing (auto-generated if not set)
JWT_SECRET=test-jwt-secret-change-in-production

# Mailler API URL for the /send-test page (standalone: port 3000 direct)
MAILLER_API_URL=http://localhost:3000

# Authorization code expiration (seconds)
CODE_EXPIRATION=300

# Token expiration (seconds)
ACCESS_TOKEN_EXPIRATION=3600
ID_TOKEN_EXPIRATION=3600
