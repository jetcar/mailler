# Database
DATABASE_URL=postgresql://mailler_user:secure_password@localhost:5432/mailler
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mailler
DB_USER=mailler_user
DB_PASSWORD=secure_password

# Database Migrations (similar to EF Core)
# Set to 'false' to disable automatic migrations on startup
AUTO_MIGRATE=true

# OpenID Connect (OIDC provider)
OIDC_ISSUER=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here
OIDC_CALLBACK_URL=http://localhost:3000/auth/callback
OIDC_SCOPE=openid profile email

# Session
SESSION_SECRET=change_this_to_a_random_secret_32_chars_minimum
SESSION_COOKIE_DOMAIN=localhost

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Encryption (for storing email passwords)
ENCRYPTION_KEY=change_this_32_char_encryption_key
