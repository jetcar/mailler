# Database
DATABASE_URL=postgresql://postgres:change-me-postgres-password@localhost:5432/mailler
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mailler
DB_USER=postgres
DB_PASSWORD=change-me-postgres-password

# Database Migrations (similar to EF Core)
# Set to 'false' to disable automatic migrations on startup
AUTO_MIGRATE=true

# OpenID Connect
OIDC_ISSUER=https://your-oidc-provider.example.com/openidc/
OIDC_CLIENT_ID=MailuId
OIDC_CLIENT_SECRET=local-test-client-secret
OIDC_CALLBACK_URL=https://localhost/webmail/oauth2/authorize
OIDC_SCOPE=openid profile email

# Session
SESSION_SECRET=change_this_to_a_random_secret_32_chars_minimum
SESSION_COOKIE_DOMAIN=localhost
TRUST_PROXY=true

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://localhost

# Encryption (for storing email passwords)
ENCRYPTION_KEY=change_this_32_char_encryption_key
