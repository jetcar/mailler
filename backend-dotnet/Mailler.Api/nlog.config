<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <variable name="logDir" value="${basedir}/logs" />
  <variable name="severity"
            value="${replace:searchFor=FATAL:replaceWith=CRITICAL:inner=${replace:searchFor=WARN:replaceWith=WARNING:inner=${level:uppercase=true}}}" />

  <!-- Console target is synchronous so logs are never lost on container shutdown (SIGTERM). -->
  <targets>
    <target xsi:type="Console"
            name="console"
            stdErr="false">
      <layout xsi:type="JsonLayout" includeAllProperties="true" suppressSpaces="true">
        <attribute name="timestamp" layout="${date:universalTime=true:format=o}" />
        <attribute name="severity" layout="${var:severity}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${message}" />
        <attribute name="exception" layout="${exception:format=tostring}" includeEmptyValue="false" />
      </layout>
    </target>

    <target xsi:type="AsyncWrapper" name="file-async" queueLimit="10000" overflowAction="Discard">
      <target xsi:type="File"
              name="file"
              fileName="${var:logDir}/mailler-${shortdate}.log"
              archiveEvery="Day"
              maxArchiveFiles="14"
              createDirs="true">
        <layout xsi:type="JsonLayout" includeAllProperties="true" suppressSpaces="true">
          <attribute name="timestamp" layout="${date:universalTime=true:format=o}" />
          <attribute name="severity" layout="${var:severity}" />
          <attribute name="logger" layout="${logger}" />
          <attribute name="message" layout="${message}" />
          <attribute name="exception" layout="${exception:format=tostring}" includeEmptyValue="false" />
        </layout>
      </target>
    </target>
  </targets>

  <rules>
    <!-- Suppress verbose ASP.NET Core framework Info/Debug/Trace logs. -->
    <logger name="Microsoft.AspNetCore.*" maxlevel="Info" final="true" />
    <!-- Forward Warn+ from ASP.NET Core and everything else at Info+. -->
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Info"  writeTo="console,file-async" final="true" />
    <logger name="*"                          minlevel="Warn"  writeTo="console,file-async" final="true" />
    <logger name="*"                          minlevel="Info"  writeTo="console,file-async" />
  </rules>
</nlog>