# Mailler Environment Configuration
# Copy this to .env and fill in your values

# ========== Database Configuration ==========
POSTGRES_DB=mailler
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ========== Backend Database Connection ==========
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/mailler
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mailler
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
PORT=3000
TRUST_PROXY=true
NODE_ENV=development
AUTO_MIGRATE=true

# ========== OpenID Connect Configuration ==========
# For production: Use real OIDC provider (OIDC provider, Auth0, etc.)
OIDC_ISSUER=https://your-oidc-provider.example.com/openidc
# Public issuer URL (for browser redirects, if different from OIDC_ISSUER)
OIDC_PUBLIC_ISSUER=https://your-oidc-provider.example.com/openidc
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here
OIDC_CALLBACK_URL=https://host.docker.internal/mailler/oauth2/authorize
OIDC_SCOPE=openid profile email

# ========== Security Secrets ==========
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_random_32_character_secret_here
# Generate encryption key - MUST be exactly 32 characters
# Generate with: openssl rand -base64 24
ENCRYPTION_KEY=12345678901234567890123456789012

# ========== Application URLs ==========
FRONTEND_URL=https://localhost

# ========== Test OIDC Provider Settings ==========
# Only used when running with .env.test
# These settings configure the test OIDC provider container
OIDC_PROVIDER_PORT=9000
OIDC_PROVIDER_ISSUER=http://test-oidc-provider:9000
OIDC_PROVIDER_USER_SUB=test-user-12345
OIDC_PROVIDER_USER_EMAIL=test@example.com
OIDC_PROVIDER_USER_NAME=Test User
OIDC_PROVIDER_USER_PREFERRED_USERNAME=testuser

# Test OIDC Provider environment variables (for the container itself)
ISSUER=http://test-oidc-provider:9000
CLIENT_ID=MailuId
CLIENT_SECRET=local-test-client-secret
USER_SUB=test-user-12345
USER_EMAIL=test@example.com
USER_NAME=Test User
USER_PREFERRED_USERNAME=testuser

# Test OIDC Provider optional settings
CODE_EXPIRATION=300
ACCESS_TOKEN_EXPIRATION=3600
ID_TOKEN_EXPIRATION=3600
