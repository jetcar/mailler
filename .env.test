# Environment variables for Docker Compose - TEST MODE
# This configuration uses the local test OIDC provider

# Database (using actual credentials from backend/.env)
POSTGRES_DB=mailler
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# Backend Database Connection
DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/mailler
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mailler
DB_USER=postgres
DB_PASSWORD=change-me-postgres-password

# Redis (for sessions - running manually on host)
REDIS_URL=redis://host.docker.internal:6379

TRUST_PROXY=true
NODE_ENV=development
NODE_TLS_REJECT_UNAUTHORIZED=0
AUTO_MIGRATE=true

# OpenID Connect (Test Provider - runs in Docker, accessed via HAProxy)
# Backend connects directly to container, browser uses HAProxy
OIDC_ISSUER=http://test-oidc-provider:9000
OIDC_PUBLIC_ISSUER=https://host.docker.internal/test_openidc
OIDC_CLIENT_ID=MailuId
OIDC_CLIENT_SECRET=local-test-client-secret
OIDC_CALLBACK_URL=https://host.docker.internal/webmail/oauth2/authorize
OIDC_SCOPE=openid profile email

# Session & Security
SESSION_SECRET=change_this_to_a_random_secret_32_chars_minimum
ENCRYPTION_KEY=change_this_32_character_encryption_key

# Frontend URL
FRONTEND_URL=https://host.docker.internal

# SMTP Listener (backend receives emails on these ports)
# Comma-separated list of ports: 25 (SMTP), 587 (Submission), 465 (SMTPS)
SMTP_PORTS=25,587,465

# Test OIDC Provider Settings
OIDC_PROVIDER_PORT=9000
# Test OIDC provider returns this URL in discovery (must match what browser uses)
OIDC_PROVIDER_ISSUER=https://localhost/oidc
OIDC_PROVIDER_USER_SUB=test-user-12345
OIDC_PROVIDER_USER_EMAIL=admin@example.com
OIDC_PROVIDER_USER_NAME=Test User
OIDC_PROVIDER_USER_PREFERRED_USERNAME=testuser

# Test OIDC Provider mapped variables (for the container)
# ISSUER is used internally for JWT validation
# PUBLIC_ISSUER is what gets returned in discovery document for browser access
ISSUER=http://test-oidc-provider:9000
PUBLIC_ISSUER=https://host.docker.internal/test_openidc
CLIENT_ID=MailuId
CLIENT_SECRET=local-test-client-secret
USER_SUB=test-user-12345
USER_EMAIL=admin@example.com
USER_NAME=Test User
USER_PREFERRED_USERNAME=testuser

# Test OIDC Provider optional settings
CODE_EXPIRATION=300
ACCESS_TOKEN_EXPIRATION=3600
ID_TOKEN_EXPIRATION=3600
